{
    "manifest_version": 3,
    "name": "Accessibility Analyzer",
    "version": "2.0",
    "description": "Comprehensive WCAG accessibility analyzer with visual highlights and detailed reports",
    "permissions": [
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "<all_urls>"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "48": "icons/icon48.png"
        }
    },
    "content_scripts": [
        {
            "matches": [
                "<all_urls>"
            ],
            "js": [
                "content.js"
            ],
            "css": [
                "content.css"
            ],
            "run_at": "document_idle"
        }
    ],
    "icons": {
        "48": "icons/icon48.png"
    }
}